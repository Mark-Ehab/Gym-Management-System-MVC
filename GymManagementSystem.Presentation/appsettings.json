{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "IdentitySeeders": {
    "SuperAdminEmail": "superadmin@gympro.com",
    "SuperAdminPassword": "Superadminp@$$w0rd",
    "AdminEmail": "admin@gympro.com",
    "AdminPassword": "Adminp@$$w0rd"
  },
  "AllowedHosts": "*"
}
