@model IEnumerable<AllPlansViewModel>

@* Alert Messages *@
@if (@TempData["SuccessAlert"] is not null)
{
    @* Show Success Messages *@
    <div id="Alert" class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessAlert"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
else if (@TempData["FailureAlert"] is not null)
{
    @* Show Error Messages *@
    <div id="Alert" class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["FailureAlert"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
    
<header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
    <div>
        <h2 class="text-primary-color mb-0">Membership Plans</h2>
        <p class="text-muted">Manage your gym membership packages</p>
    </div>
</header>
@if(Model.Any())
{
    <div class="row g-4">
        @* Loop Through Plans and Display Each Plan in a Card *@
        @foreach (var plan in Model)
        {
            var planAcivationBtnTxtColor = plan.Active ? "text-danger" : "text-success";
            var planCardHeaderColor = plan.Active ? "bg-primary-color" : "bg-secondary";

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 plan-card">
                    @* If Plan is Active put class bg-primary-color if not bg-secondary *@
                        <div class="card-header text-white text-center py-4 @planCardHeaderColor">
                        <h4 class="mb-0">@plan.Name</h4>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <div class="text-center mb-4">
                            <div class="display-4 fw-bold text-primary-color">@plan.Price</div>
                            <small class="text-muted">EGP</small>
                        </div>

                        <div class="mb-3">
                            <p class="text-muted mb-2">
                                <i class="bi bi-calendar-check text-primary-color me-2"></i>
                                <strong>Duration:</strong> @plan.DurationDays
                            </p>
                            <p class="text-muted mb-3">
                                <i class="bi bi-file-text text-primary-color me-2"></i>
                                <strong>Description:</strong>
                            </p>
                            <p class="small">@plan.Description</p>
                        </div>

                        <div class="mt-auto">
                            <div class="d-grid gap-2">

                                <a asp-controller="Plans" asp-action="Details" asp-route-id="@plan.Id" class="btn btn-outline btn-sm">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>

                                <div class="d-flex gap-2">
                                    <a asp-controller="Plans" asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-outline btn-sm flex-fill">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <form asp-controller="Plans" asp-action="Activate" asp-route-id ="@plan.Id" method="post" class="flex-fill">
                                        @* If Plan is Active put class text-danger if not text-success *@
                                            <button type="submit" class="btn btn-outline btn-sm w-100 @planAcivationBtnTxtColor">
                                            @if (plan.Active)
                                            {
                                                @* Display If No Plan is inactive*@
                                                <i class="bi bi-x-circle me-1"> Deactivate </i>
                                            }
                                            else
                                            {
                                                @* Display If No Plan is Active*@
                                                <i class="bi bi-check-circle me-1"> Activate </i>
                                            }
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    @* Display This Div If No Plans Are Available *@
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">No Plans Available</h4>
    </div>
}

@section Scripts
{
    <partial name="_AlertScriptPartial" />
}