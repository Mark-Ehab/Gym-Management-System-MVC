@{
    var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    string setActive(string navLinkName)
        => string.Equals(controllerName, navLinkName, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+Thambi+2:wght@400..800&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <!-- ^ Bootstrap 5.3.8 css file -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- ^ Our main css file -->
    <link rel="stylesheet" href="~/css/style.css" />
    <title>Power fitness | Home</title>
</head>
<body>
    <header>
        <!-- ^ navbar -->
        <nav class="navbar navbar-expand-lg bg-white my-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="home" asp-action="index">
                    <img src="~/images/logo.jpg" alt="Power Fitness Icon" asp-append-version ="true"/>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav m-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                        <li class="nav-item">
                        <li class="nav-item">
                                <a class="nav-link @setActive("Home") px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Home") == "active"? "page" : null)" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @setActive("Members")  px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Members") == "active"? "page" : null)" asp-controller="Members" asp-action="Index">Members</a>
                        </li>
                        <li class="nav-item">
                                <a class="nav-link @setActive("Trainers")  px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Trainers") == "active"? "page" : null)" asp-controller="Trainers" asp-action="Index">Trainers</a>
                        </li>
                        <li class="nav-item">
                                <a class="nav-link @setActive("Sessions")  px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Sessions") == "active"? "page" : null)" asp-controller="Sessions" asp-action="Index">Sessions</a>
                        </li>
                        <li class="nav-item">
                                <a class="nav-link @setActive("Plans") px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Plans") == "active"? "page" : null)" asp-controller="Plans" asp-action="Index">Plans</a>
                        </li>
                        <li class="nav-item">
                                <a class="nav-link @setActive("Memberships") px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Memberships") == "active"? "page" : null)" asp-controller="Memberships" asp-action="Index">Memberships</a>
                        </li>
                        <li class="nav-item">
                                <a class="nav-link @setActive("Sessions Schedule") px-3 py-2 mx-2 fw-bolder fs-5" aria-current="@(setActive("Sessions Schedule") == "active"? "page" : null)" asp-controller="SessionsSchedule" asp-action="Index">Sessions Schedule</a>
                        </li>
                        <li class="nav-item">
                            <form href="\Account\Logout" method="post" class="d-inline">
                                <button type="submit"
                                    class="btn btn-link nav-link px-3 py-2 mx-2 fw-bolder fs-5 text-black-alternative">
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
         <main role="main" class="pb-3"> 
            @RenderBody()
         </main> 
    </div>

    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GymManagementSystem.Presentation - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
