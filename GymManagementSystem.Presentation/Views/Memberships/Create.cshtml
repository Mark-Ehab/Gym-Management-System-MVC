@model CreateMembershipViewModel

@if (@TempData["FailureAlert"] is not null)
{
    <div id="Alert" class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["FailureAlert"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                @* <div class="card-header">
                    <h4>@ViewData["Title"]</h4>
                </div> *@
                <div class="card-header text-center">Add New Membership</div>
                <div class="card-body">
                    <form method="post">

                        <div class="mb-3">
                            <label class="form-label">Member</label>
                            <select class="form-select" asp-items="ViewBag.Members" asp-for="Member">
                                <option value="">-- Select Member --</option>
                            </select>
                            <span asp-validation-for="Member"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Plan</label>
                            <select class="form-select" asp-items="ViewBag.Plans" asp-for="Plan">
                                <option value="">-- Select Plan --</option>
                            </select>
                            <span asp-validation-for="Plan"></span>
                        </div>

                        <div class="mb-3">
                            <button type="submit" class="btn btn-primary">Create Membership</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    <partial name="_AlertScriptPartial" />
}